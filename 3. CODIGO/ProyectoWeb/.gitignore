# Dependencias de Node (Súper pesadas, nunca se suben)
node_modules/
dist/

# Temporales de Astro y compilación de Vite
.astro/
.output/
.vercel/
.netlify/

# Caché del compilador en entornos Linux (Fedora)
.vite/
.cache/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Archivos de entorno y credenciales ocultas (Por si luego usas variables .env)
.env
.env.local
.env.production
.env.development

# Archivos temporales del sistema operativo (Linux/Fedora y otros)
.DS_Store
Thumbs.db
*.local

